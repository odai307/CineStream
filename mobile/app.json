{
  "expo": {
    "name": "CineStream",
    "slug": "cinestream-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": ["ios", "android"],
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cinestream.mobile"
    },
    "android": {
      "package": "com.cinestream.mobile"
    }
  }
}
